# Example copy of packaging/steam/targets.env

# Main game.
STEAM_APP_ID=4945920

# Content depot created for the Windows build.
STEAM_DEPOT_WINDOWS=4945921

# Content depot created for the macOS app bundle.
STEAM_DEPOT_MACOS=4945922

# Steam Playtest child app and its all-platform depot.
STEAM_PLAYTEST_APP_ID=4946320
STEAM_PLAYTEST_DEPOT=4946321

# Branch used by scripts/steam-upload.sh --beta. Defaults to beta.
# STEAM_BETA_BRANCH=beta

# Optional branch to set live on the Playtest app after upload.
# STEAM_PLAYTEST_BRANCH=playtest-beta
